# Copy this file to .env and fill in real values for local development.
# On Replit, these are already provided as environment variables/secrets and
# this file is not required.

# MongoDB connection string (no default — required)
MONGO_URL=mongodb://127.0.0.1:27017

# MongoDB database name (no default — required)
DB_NAME=ranthambore_safari_curator

# Admin PIN used to authenticate all /api/admin/* routes via the
# X-Admin-Pin header (no default — required, the server refuses to start
# without it)
ADMIN_PIN=change-me

# Comma-separated list of allowed CORS origins, e.g.
# https://ranthamborecurator.com,https://www.ranthamborecurator.com
# Defaults to "*" in development and to a restrictive (empty) policy in
# production if left unset.
CORS_ORIGINS=*

# Port the Express server listens on (default: 8001)
PORT=8001

# development | production
NODE_ENV=development
